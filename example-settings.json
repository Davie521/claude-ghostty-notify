{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "GHOSTTY_NOTIFY_MIN_ELAPSED": "45",
    "GHOSTTY_NOTIFY_SOUND_ELAPSED": "120",
    "GHOSTTY_NOTIFY_TIMEOUT": "600"
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "idle_prompt|permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/YOUR_USERNAME/.claude/hooks/ghostty-notify.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/YOUR_USERNAME/.claude/hooks/ghostty-tab-save.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/YOUR_USERNAME/.claude/hooks/ghostty-notify.sh"
          }
        ]
      }
    ]
  }
}
